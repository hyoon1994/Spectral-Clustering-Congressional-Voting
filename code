    {
      "cell_type": "code",
      "source": [
        "#step 2A: build unnormalized graph laplacian from x then compute second eigenvector (fiedler vector)\n",
        "\n",
        "import numpy as np\n",
        "from scipy.spatial.distance import cdist\n",
        "\n",
        "# Choose a sigma value to start with\n",
        "sigma = 1.0\n",
        "\n",
        "# Pairwise squared Euclidean distances between all rows of X\n",
        "dist2 = cdist(X, X, metric=\"sqeuclidean\")\n",
        "\n",
        "# Weight matrix W using the Gaussian kernel\n",
        "W = np.exp(-dist2 / (2 * sigma**2))\n",
        "\n",
        "# Degree matrix D\n",
        "D = np.diag(W.sum(axis=1))\n",
        "\n",
        "# Unnormalized graph Laplacian\n",
        "L = D - W\n",
        "\n",
        "# Eigen-decomposition of L\n",
        "# eigh is for symmetric matrices\n",
        "eigvals, eigvecs = np.linalg.eigh(L)\n",
        "\n",
        "# Second eigenvector = Fiedler vector\n",
        "q1 = eigvecs[:, 1]\n",
        "\n",
        "print(\"L shape:\", L.shape)\n",
        "print(\"First 5 eigenvalues:\", eigvals[:5])\n",
        "print(\"q1 shape:\", q1.shape)"
      ],
