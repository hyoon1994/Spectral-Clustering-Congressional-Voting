    {
      "cell_type": "code",
      "source": [
        "#2C vary the parameter  in the gaussian weight function, compute clustering accuracy for each value, and plot accuracy v\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.spatial.distance import cdist\n",
        "\n",
        "sigmas = np.linspace(0.1, 4, 40)   # range of sigma values\n",
        "accuracies = []\n",
        "\n",
        "for sigma in sigmas:\n",
        "\n",
        "    # Compute pairwise squared distances\n",
        "    dist2 = cdist(X, X, metric=\"sqeuclidean\")\n",
        "\n",
        "    # Weight matrix\n",
        "    W = np.exp(-dist2 / (2 * sigma**2))\n",
        "\n",
        "    # Degree matrix\n",
        "    D = np.diag(W.sum(axis=1))\n",
        "\n",
        "    # Laplacian\n",
        "    L = D - W\n",
        "\n",
        "    # Eigen decomposition\n",
        "    eigvals, eigvecs = np.linalg.eigh(L)\n",
        "\n",
        "    # Fiedler vector\n",
        "    q1 = eigvecs[:,1]\n",
        "\n",
        "    # Predicted labels\n",
        "    y_pred = np.sign(q1)\n",
        "    y_pred[y_pred == 0] = 1\n",
        "\n",
        "    # Accuracy (account for sign flip)\n",
        "    acc1 = np.mean(y_pred == y)\n",
        "    acc2 = np.mean(-y_pred == y)\n",
        "\n",
        "    accuracies.append(max(acc1, acc2))\n",
        "\n",
        "accuracies = np.array(accuracies)\n",
        "\n",
        "\n",
        "# Find the optimal\n",
        "\n",
        "best_index = np.argmax(accuracies)\n",
        "sigma_star = sigmas[best_index]\n",
        "\n",
        "print(\"Optimal sigma:\", sigma_star)\n",
        "print(\"Best accuracy:\", accuracies[best_index])\n",
        "\n",
        "# plot accuracy v. sigma\n",
        "\n",
        "plt.figure(figsize=(6,4))\n",
        "plt.plot(sigmas, accuracies)\n",
        "plt.xlabel(\"sigma\")\n",
        "plt.ylabel(\"Clustering Accuracy\")\n",
        "plt.title(\"Accuracy vs Sigma\")\n",
        "plt.show()\n"
      ],
