    {
      "cell_type": "code",
      "source": [
        "# step 3c train linear regression model\n",
        "\n",
        "# Solve least squares problem\n",
        "beta_hat = np.linalg.lstsq(A, b, rcond=None)[0]\n",
        "\n",
        "# Predict labels for all members\n",
        "y_pred = np.sign(F @ beta_hat)\n",
        "\n",
        "# Handle any zeros\n",
        "y_pred[y_pred == 0] = 1\n",
        "\n",
        "# Compute accuracy\n",
        "misclassified = np.sum(y_pred != y)\n",
        "accuracy = 1 - misclassified / len(y)\n",
        "\n",
        "print(\"Misclassified members:\", misclassified)\n",
        "print(\"SSL accuracy:\", accuracy)"
