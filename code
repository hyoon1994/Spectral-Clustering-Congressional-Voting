    {
      "cell_type": "code",
      "source": [
        "# step 2B classifer and compute accuracy\n",
        "\n",
        "# Step 2b: classify using sign(q1)\n",
        "\n",
        "y_pred = np.sign(q1)\n",
        "\n",
        "# If any entry is exactly 0, assign it to +1\n",
        "y_pred[y_pred == 0] = 1\n",
        "\n",
        "# Accuracy without sign flip\n",
        "acc1 = np.mean(y_pred == y)\n",
        "\n",
        "# Accuracy with sign flip\n",
        "acc2 = np.mean(-y_pred == y)\n",
        "\n",
        "# Pick the better orientation\n",
        "if acc2 > acc1:\n",
        "    y_pred = -y_pred\n",
        "    best_acc = acc2\n",
        "else:\n",
        "    best_acc = acc1\n",
        "\n",
        "# Misclassified count\n",
        "misclassified = np.sum(y_pred != y)\n",
        "\n",
        "print(\"Accuracy without sign flip:\", acc1)\n",
        "print(\"Accuracy with sign flip:\", acc2)\n",
        "print(\"Best clustering accuracy:\", best_acc)\n",
        "print(\"Misclassified members:\", misclassified)"
      ],
