        "#step 1 convert categorical data into numbers to prep for machine learning\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "data = pd.read_csv(\"datasets/house-votes-84.data\", header=None)\n",
        "\n",
