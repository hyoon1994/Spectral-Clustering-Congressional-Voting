        "# step 3B Here are 10 members whose party I know. Use their graph features to learn how to predict party labels\n",
        "\n",
        "J = 10   # number of labeled members\n",
        "\n",
        "A = F[:J, :]\n",
        "b = y[:J]\n",
        "\n",
        "print(\"A shape:\", A.shape)\n",
        "print(\"b shape:\", b.shape)"
      ],
